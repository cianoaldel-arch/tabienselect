# ==========================================================
# Single source of truth for all services.
# Loaded by: docker-compose, backend (src/config/env.js), frontend (next.config.js)
# ==========================================================

# ---------- Postgres ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
POSTGRES_DB=tabienselect
POSTGRES_PORT=5432

# ---------- Backend ----------
BACKEND_PORT=4000
NODE_ENV=development
# Local dev uses localhost; docker-compose overrides this to use the `postgres` service hostname.
DATABASE_URL=postgresql://postgres:root@localhost:5432/tabienselect?schema=public
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=1d  
ADMIN_EMAIL=admin@tabienselect.local
ADMIN_PASSWORD=changeme123

# ---------- Frontend ----------
FRONTEND_PORT=3000
# Public URL the browser uses to reach the API.
# Local:           http://localhost:4000/api
# Production:      https://api.tabien-select.com/api
NEXT_PUBLIC_API_URL=https://api.tabien-select.com/api
