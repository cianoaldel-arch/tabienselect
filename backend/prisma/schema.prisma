generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Plate {
  id             String   @id @default(cuid())
  prefix         String
  number         String
  full_plate     String   @unique
  category       String
  plate_type     String
  numerology_sum Int
  price          Int      @default(0)
  line_qr_url    String
  contact_text   String
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@index([category])
  @@index([plate_type])
}

model AdminUser {
  id            String   @id @default(cuid())
  email         String   @unique
  password_hash String
  created_at    DateTime @default(now())
}

model Theme {
  id         String   @id @default(cuid())
  name       String   @unique
  primary    String
  accent     String
  background String
  foreground String
  muted      String
  is_active  Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model Config {
  id         String   @id @default(cuid())
  key        String   @unique
  value      String
  updated_at DateTime @updatedAt
}

model PromoBanner {
  id             String   @id @default(cuid())
  headline       String
  highlight      String
  subheadline    String?
  plate_code     String
  plate_region   String
  image_url      String?
  footer_title   String
  footer_tagline String
  phone          String
  line_id        String
  sort_order     Int      @default(0)
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@index([is_active])
  @@index([sort_order])
}
