# ==========================================================
# Template for .env — copy to .env and fill in real values.
#   cp .env.example .env
#
# .env is gitignored. Each environment (local / staging / prod)
# maintains its own .env file directly on the host. Never commit
# real secrets.
#
# IMPORTANT — POSTGRES_PASSWORD drift:
#   The postgres image reads POSTGRES_PASSWORD ONLY on first
#   volume init. Changing it later in .env has NO effect on the
#   running database. To rotate the password you must either:
#     (a) ALTER USER postgres WITH PASSWORD '...';   inside psql, or
#     (b) docker compose down + docker volume rm + docker compose up
#         (this destroys all data — backup first).
#
# IMPORTANT — POSTGRES_PASSWORD characters:
#   Avoid characters that have special meaning in URLs:
#     @ : / ? # [ ] ! $ & ' ( ) * + , ; = %
#   Safe to use: a-z A-Z 0-9 - _ .
#   The compose file substitutes POSTGRES_PASSWORD into DATABASE_URL
#   without URL-encoding, so an unsafe character will break auth.
# ==========================================================

# ---------- Postgres ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_me_with_strong_password
POSTGRES_DB=tabienselect
# Only used when running with docker-compose.dev.yml (host port for DB tools).
POSTGRES_PORT=5432

# ---------- Backend ----------
BACKEND_PORT=4000
NODE_ENV=development
# Local non-docker dev value. Inside docker compose, DATABASE_URL is
# overridden so the host is `postgres` (the compose service name).
DATABASE_URL=postgresql://postgres:replace_me_with_strong_password@localhost:5432/tabienselect?schema=public
CORS_ORIGIN=http://localhost:3000
# Generate with:  openssl rand -base64 48
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_EXPIRES_IN=1d
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_me

# ---------- Frontend ----------
FRONTEND_PORT=3000
# Public URL the browser uses to reach the API.
#   Local:       http://localhost:4000/api
#   Production:  https://api.your-domain.com/api
NEXT_PUBLIC_API_URL=http://localhost:4000/api
