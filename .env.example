# ==========================================================
# Template for local / production .env files.
# Copy to `.env` in the project root and fill in real values.
# DO NOT commit `.env` — it is gitignored.
# ==========================================================

# ---------- Postgres ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_me
POSTGRES_DB=tabienselect
POSTGRES_PORT=5432

# ---------- Backend ----------
BACKEND_PORT=4000
NODE_ENV=development

# Local dev (running backend outside docker):     postgresql://<user>:<pass>@localhost:5432/<db>?schema=public
# Docker compose:                                 docker-compose.yml overrides this with the `postgres` service hostname,
#                                                 so the value below only matters outside of compose.
DATABASE_URL=postgresql://postgres:replace_me@localhost:5432/tabienselect?schema=public

CORS_ORIGIN=http://localhost:3000
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=1d
ADMIN_EMAIL=admin@tabienselect.local
ADMIN_PASSWORD=replace_me

# ---------- Frontend ----------
FRONTEND_PORT=3000
# Public URL the browser uses to reach the API.
# Local:        http://localhost:4000/api
# Production:   https://api.your-domain.com/api
NEXT_PUBLIC_API_URL=http://localhost:4000/api
